{
    "name":  "tourism-chatbot",
    "private":  true,
    "version":  "1.0.0",
    "packageManager":  "pnpm@10.18.3",
    "scripts":  {
                    "dev":  "corepack pnpm --parallel --filter server --filter client dev",
                    "dev:server":  "corepack pnpm --filter server dev",
                    "dev:client":  "corepack pnpm --filter client dev",
                    "build":  "corepack pnpm -r build",
                    "start":  "corepack pnpm --filter server start",
                    "start:server":  "corepack pnpm --filter server start",
                    "start:be":  "corepack pnpm --filter server start",
                    "start:client":  "corepack pnpm --filter client start"
                }
}
