{
  "name": "server",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "node --import @swc-node/register/esm-register --watch src/main.ts",
    "start": "node --import @swc-node/register/esm-register src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start:prod": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:push": "prisma db push",
    "db:up": "docker compose -f ../docker-compose.yml up -d postgres",
    "db:down": "docker compose -f ../docker-compose.yml down",
    "db:logs": "docker compose -f ../docker-compose.yml logs -f postgres"
  },
  "dependencies": {
    "@apollo/server": "^4.12.2",
    "@as-integrations/express5": "^1.1.2",
    "@google/genai": "^1.28.0",
    "@nestjs/apollo": "^13.2.4",
    "@nestjs/common": "^11.1.6",
    "@nestjs/core": "^11.1.6",
    "@nestjs/graphql": "^13.2.4",
    "@nestjs/platform-express": "^11.1.6",
    "@prisma/client": "^6.16.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "dotenv": "^17.2.3",
    "graphql": "^16.11.0",
    "prisma": "^6.16.2",
    "reflect-metadata": "^0.1.14",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@swc-node/register": "^1.11.1",
    "@swc/core": "^1.15.21",
    "@types/node": "^24.5.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
